---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  page="404"
  title="Page not found – COGNAK"
  description="The page you were looking for doesn't exist."
  noindex={true}
  pageBg="#6F6F6F"
>
  <style is:inline>{`
/* ── Navbar — desktop ── */
.fourofour-nav {
    background: rgba(129, 129, 129, 0.95) !important;
    backdrop-filter: blur(6px) !important;
    -webkit-backdrop-filter: blur(6px) !important;
    z-index: 999999 !important;
}
.fourofour-nav img { filter: none !important; }
.fourofour-nav .home-bottom-email,
.fourofour-nav .home-bottom-location,
.fourofour-nav .inner-nav-links a { color: #EEEEEE !important; }
.fourofour-nav .pulse-dot { color: #9EED3D !important; }
.fourofour-nav .home-bottom-email:hover,
.fourofour-nav .inner-nav-links a:hover { color: #9EED3D !important; }

/* ── Layout ── */
.fourofour-template {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 190px 80px 100px;
    box-sizing: border-box;
}

/* ── Headline ── */
.fourofour-headline {
    font-family: "Inter", sans-serif;
    font-size: clamp(20px, 5.5vw, 62px);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    margin: 0 0 90px 100px;
    max-width: 1000px;
}

.fourofour-accent { color: #D1D1D1; white-space: nowrap; }

.fourofour-frown {
    display: inline-block;
    transition: transform 1.6s ease;
    transform-origin: center;
}
.fourofour-headline:hover .fourofour-frown { transform: rotate(22deg); }

.fourofour-body {
    font-family: "Inter", sans-serif;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.7;
    color: #F3F3F3;
    max-width: 480px;
    margin: 0 0 64px 300px;
}

.fourofour-buttons {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin-left: 300px;
}

.fourofour-btn {
    font-family: "Inter", sans-serif;
    font-size: clamp(22px, 3.0vw, 58px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #D4D4D4;
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
}
.fourofour-btn:hover { color: #9EED3D; }

@media (max-width: 720px) {
    .home-bottom-bar.inner-page-nav.fourofour-nav {
        background: rgba(129, 129, 129, 0.95) !important;
    }
    .fourofour-nav .home-bottom-email,
    .fourofour-nav .home-bottom-location,
    .fourofour-nav .inner-nav-links a { color: #EEEEEE !important; }
    .fourofour-template { padding: 140px 24px 64px; }
    .fourofour-headline { font-size: clamp(24px, 7vw, 42px); margin: 0 0 32px 0; }
    .fourofour-body { font-size: 14px; margin: 0 0 48px 0; }
    .fourofour-buttons { margin-left: 0; gap: 24px; }
    .fourofour-btn { font-size: clamp(32px, 8vw, 48px); }
}
`}</style>

  <main id="cognak-main">
    <section class="fourofour-template">
      <h1 class="fourofour-headline">You've caught us in a <span class="fourofour-accent">404 error.</span><br>This page doesn't exist <span class="fourofour-frown" aria-hidden="true">:(</span></h1>
      <p class="fourofour-body">You accidentally followed a dead link, mistyped something, or we moved it without telling anyone. Either way, we're glad you're here.</p>
      <div class="fourofour-buttons">
        <a href="/projects" class="fourofour-btn">View projects</a>
        <a href="/studio" class="fourofour-btn">Discover the studio</a>
      </div>
    </section>
  </main>
</BaseLayout>

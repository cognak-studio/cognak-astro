---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import fs from 'node:fs';

export async function getStaticPaths() {
  const all = (await getCollection('projects', (p) => !p.data.draft));
  // Newest-first ordering (get_adjacent_post by date) for prev/next.
  const ordered = [...all].sort((a, b) => {
    const ta = a.data.date ? a.data.date.getTime() : 0;
    const tb = b.data.date ? b.data.date.getTime() : 0;
    return tb - ta;
  });
  return ordered.map((entry, i) => {
    // WordPress: "previous" = older (next in newest-first list),
    // "next" = newer (previous in list); newest wraps to oldest.
    const prev = ordered[i + 1] ?? null; // older
    let next = ordered[i - 1] ?? null;   // newer
    if (!next && ordered.length > 1) next = ordered[ordered.length - 1]; // wrap
    return {
      params: { slug: entry.data.slug ?? entry.slug },
      props: {
        entry,
        prev: prev ? { slug: prev.data.slug ?? prev.slug, title: prev.data.title } : null,
        next: next && next.id !== entry.id ? { slug: next.data.slug ?? next.slug, title: next.data.title } : null,
      },
    };
  });
}

const { entry, prev, next } = Astro.props;
const d = entry.data;
const slug = d.slug ?? entry.slug;
// The project's gallery (ACF "figures") lives in the markdown body.
const { Content } = await entry.render();

const heroImg = await getImage({ src: d.hero, format: 'webp', width: 2000 });
// Branded OG share image (pre-generated by scripts/generate-og.py, mirrors the old
// og-image.php compositor). Falls back to the hero image if a card hasn't been
// generated yet, so a freshly-added project never has a broken share preview.
const ogCard = new URL(`../../../public/og/${slug}.jpg`, import.meta.url);
const ogImage = fs.existsSync(ogCard)
  ? `https://cognak.com/og/${slug}.jpg`
  : `https://cognak.com${heroImg.src}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: d.title,
  url: `https://cognak.com/projects/${slug}/`,
  description: d.metaDescription ?? '',
  creator: { '@type': 'Organization', name: 'COGNAK', url: 'https://cognak.com' },
  image: ogImage,
};
---
<BaseLayout
  page="project"
  title={`${d.title} – COGNAK`}
  description={d.metaDescription ?? `${d.title} — by COGNAK.`}
  ogType="article"
  ogImage={ogImage}
  ogUrl={`https://cognak.com/projects/${slug}/`}
  noindex={d.noindex}
  jsonLd={jsonLd}
  heroPreload={heroImg.src}
>
  <main id="cognak-main"><article class="template-single-project">

    <figure class="img-wide img-wide--hero" style={`view-transition-name: project-thumb-${slug}`}>
      {d.heroVideo ? (
        <>
          <video class="hero-video" src={d.heroVideo} autoplay muted loop playsinline webkit-playsinline x5-playsinline poster={heroImg.src}></video>
          <button class="hero-mute-btn" aria-label="Toggle sound">
            <svg class="hero-mute-icon hero-mute-icon--muted" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8H7L12 4V18L7 14H3V8Z" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
              <line x1="16" y1="8" x2="20" y2="14" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="20" y1="8" x2="16" y2="14" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg class="hero-mute-icon hero-mute-icon--unmuted" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none">
              <path d="M3 8H7L12 4V18L7 14H3V8Z" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M15 7.5C16.5 8.8 17.5 10.3 17.5 11S16.5 13.2 15 14.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M17.5 5C20 7 21.5 9 21.5 11S20 15 17.5 17" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </>
      ) : (
        <img src={heroImg.src} alt={`${d.title} – COGNAK`} width={heroImg.attributes.width} height={heroImg.attributes.height} />
      )}

      {(prev || next) && (
        <div class="mobile-project-nav">
          {prev && (
            <a href={`/projects/${prev.slug}`} class="mobile-pager mobile-pager--prev" aria-label={`Previous project: ${prev.title}`}>
              <span class="mobile-pager-arrow"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4L6 10L12 16" stroke="#3A313B" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="mobile-pager-title">{prev.title}</span>
            </a>
          )}
          {next && (
            <a href={`/projects/${next.slug}`} class="mobile-pager mobile-pager--next" aria-label={`Next project: ${next.title}`}>
              <span class="mobile-pager-arrow"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 4L14 10L8 16" stroke="#3A313B" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="mobile-pager-title">{next.title}</span>
            </a>
          )}
        </div>
      )}
    </figure>

    <section class="information">
      <div class="container--work-single">
        <h1 class="title">{d.title}</h1>
        <p class="category">{d.category}</p>
        <aside class="details">
          <div class="col">
            <h2>About the client</h2>
            <Fragment set:html={d.aboutTheClient ?? ''} />
          </div>
          <div class="col">
            <h2>The work</h2>
            <Fragment set:html={d.theWork ?? ''} />
          </div>
          <div class="col end">
            <h2>More details</h2>
            <Fragment set:html={d.moreDetails ?? ''} />
          </div>
        </aside>
      </div>
    </section>

    <figure class="img-wide">
      <Content />
    </figure>

    <nav id="work-pagers" class="pagers group">
      {prev && (
        <a href={`/projects/${prev.slug}`} rel="prev" aria-label={`Previous project: ${prev.title}`}>
          <span class="title">{prev.title}</span>
          <svg class="pager-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15 5L9 12L15 19" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      )}
      {next && (
        <a href={`/projects/${next.slug}`} rel="next" aria-label={`Next project: ${next.title}`}>
          <svg class="pager-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 5L15 12L9 19" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="title">{next.title}</span>
        </a>
      )}
    </nav>
  </article></main>
</BaseLayout>

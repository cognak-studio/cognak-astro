    var badges      = document.getElementById('award-badges-pop');
    var founderTriggers = document.querySelectorAll('.founder-name');
    var awardTriggers   = document.querySelectorAll('.award-name');
    var cursor      = document.getElementById('cognak-cursor');
    var cursorLabel = document.getElementById('cognak-cursor-label');
    var portraitTimer, badgesTimer;
    var activeTrigger = null;

    function clearCursorPill() {
        // Android Chrome synthesizes mouseenter on tap, so the desktop cursor pill
        // activates but mouseleave never fires. Clear it manually here.
        if (cursor)      { cursor.classList.remove('is-founder'); }
        if (cursorLabel) { cursorLabel.textContent = ''; }
    }

    function clearTrigger() {
        if (activeTrigger) { activeTrigger.classList.remove('is-tapped'); activeTrigger = null; }
        clearCursorPill();
    }

    function showFor3s(el, triggerEl, existingTimer) {
        if (!el) return existingTimer;
        clearTimeout(existingTimer);
        clearTrigger();
        el.classList.add('is-active');
        if (triggerEl) { triggerEl.classList.add('is-tapped'); activeTrigger = triggerEl; }
        return setTimeout(function() {
            el.classList.remove('is-active');
            clearTrigger();
        }, 3000);
    }

    founderTriggers.forEach(function(n) {
        n.addEventListener('click', function(e) {
            e.stopPropagation();
            portraitTimer = showFor3s(portrait, n, portraitTimer);
        });
    });

    awardTriggers.forEach(function(n) {
        n.addEventListener('click', function(e) {
            e.stopPropagation();
            badgesTimer = showFor3s(badges, n, badgesTimer);
        });
    });

    // Tap anywhere else dismisses immediately
    document.addEventListener('click', function() {
        if (portrait) portrait.classList.remove('is-active');
        if (badges)   badges.classList.remove('is-active');
        clearTimeout(portraitTimer);
        clearTimeout(badgesTimer);
        clearTrigger();
    });
})();
</script>

<script is:inline>
// ── Studio feature reel ────────────────────────────────────────────
(function() {
    // POOL is driven by ACF — edit via WP Admin → Studio page → Studio Reel
    var POOL = [{"type": "video", "src": "/uploads/2026/06/cognak-studio-video.mp4", "client": "", "kind": "", "year": ""}, {"type": "video", "src": "/uploads/2026/06/hex_blog.mp4", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2026/06/chefs-kiss-mockup-scaled.jpg", "client": "", "kind": "", "year": ""}, {"type": "video", "src": "/uploads/2026/06/verde-hero.mp4", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2015/12/ctp-website-cognak.jpg", "client": "", "kind": "", "year": ""}, {"type": "video", "src": "/uploads/2026/06/sweetgains-studio-1.mp4", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2019/07/strawberry.png", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2024/02/hypr-wall-logo-cognak-scaled.jpg", "client": "", "kind": "", "year": ""}, {"type": "video", "src": "/uploads/2026/06/1920x1080-Refresh_1.mp4", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2024/02/letterhead-cover-palisades.png", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2026/04/sidekick-component-scaled.jpg", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2022/08/nightowl-vodka-espresso-martini-bar-scaled.png", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2025/08/noreaster-riverview-school-design-cognak-scaled.jpg", "client": "", "kind": "", "year": ""}, {"type": "image", "src": "/uploads/2015/12/zynlo-mockup.jpg", "client": "", "kind": "", "year": ""}];


    // Sequential index — click advances through POOL in order, wraps around
    var reelIdx = 1; // 0 is already in the DOM

    function dequeue() {
        if (!POOL.length) return null;
        var item = POOL[reelIdx % POOL.length];
        reelIdx++;
        return item;
    }

    var wrap      = document.querySelector('.studio-feature-video-wrap');
    var stage     = document.querySelector('.sfv-stage');
    var cursor    = document.getElementById('cognak-cursor');
    var label     = document.getElementById('cognak-cursor-label');
    if (!wrap || !stage || !cursor) return;

    var currentEl = stage.querySelector('.studio-feature-media');
    var animating = false;

    // Lock the ceiling height to whatever the first asset renders at.
    // Subsequent assets can never be taller than this — they scale down proportionally.
    requestAnimationFrame(function() {
        var h = stage.offsetHeight;
        if (h > 0) stage.style.setProperty('--reel-max-h', h + 'px');
        // Typewrite meta for the first asset simultaneously with page load
        if (POOL.length) typewrite(buildMeta(POOL[0]));
    });

    // ── Meta typewriter ──
    var metaEl  = document.querySelector('.sfv-meta');
    var twTimer = null;

    function randHex(len) {
        var s = '';
        while (s.length < len) s += Math.random().toString(16).slice(2);
        return s.slice(0, len);
    }

    function buildMeta(item) {
        var fields = [];
        if (item.client) fields.push('  "client": "' + item.client + '"');
        if (item.kind)   fields.push('  "type": "' + item.kind + '"');
        if (item.year)   fields.push('  "year": ' + item.year);
        fields.push('  "render_id": "' + randHex(6) + '"');
        fields.push('  "revisions": ' + (Math.floor(Math.random() * 8) + 1));
        fields.push('  "nda": ' + (Math.random() > 0.5 ? 'true' : 'false'));
        return '{\n' + fields.join(',\n') + '\n}';
    }

    function typewrite(text) {
        if (!metaEl) return;
        clearTimeout(twTimer);
        metaEl.textContent = '';
        metaEl.style.opacity = '1';
        var i = 0;
        (function tick() {
            if (i >= text.length) return;
            metaEl.textContent += text[i++];
            twTimer = setTimeout(tick, i < 3 ? 0 : 18);
        })();
    }

    function buildEl(item) {
        var el;
        if (item.type === 'image') {
            el = document.createElement('img');
            el.className = 'studio-feature-media studio-feature-img';
            el.alt = '';
            el.src = item.src;
        } else {
            el = document.createElement('video');
            el.className = 'studio-feature-media studio-feature-video';
            el.loop = true; el.muted = true;
            el.setAttribute('playsinline', '');
            el.setAttribute('preload', 'metadata');
            var s = document.createElement('source');
            s.src = item.src; s.type = 'video/mp4';
            el.appendChild(s);
        }
        el._reelMeta = item; // stash for typewriter
        return el;
    }

    // ── Cursor ring ──
    var ns = 'http://www.w3.org/2000/svg';
    var ring = document.createElementNS(ns, 'svg');
    ring.id = 'cognak-cursor-ring';
    ring.setAttribute('viewBox', '0 0 100 100');

    var defs = document.createElementNS(ns, 'defs');
    var rp = document.createElementNS(ns, 'path');
    rp.id = 'ring-path';
    rp.setAttribute('d', 'M50,6 a44,44 0 1,1 -0.001,0');
    defs.appendChild(rp);

    // Clip path for the white over-image ring — rect updated on mousemove
    var clipId = 'ring-media-clip';
    var cp = document.createElementNS(ns, 'clipPath');
    cp.id = clipId;
    cp.setAttribute('clipPathUnits', 'userSpaceOnUse');
    var clipRect = document.createElementNS(ns, 'rect');
    clipRect.setAttribute('x', '-9999'); clipRect.setAttribute('y', '-9999');
    clipRect.setAttribute('width', '0'); clipRect.setAttribute('height', '0');
    cp.appendChild(clipRect);
    defs.appendChild(cp);
    ring.appendChild(defs);

    // Base ring — pink, always visible
    var rtxt = document.createElementNS(ns, 'text');
    rtxt.setAttribute('font-family', 'Diatype Mono Variable, monospace');
    rtxt.setAttribute('font-size', '8.5');
    rtxt.setAttribute('fill', '#FFB2E4');
    rtxt.setAttribute('letter-spacing', '2.5');
    var tp = document.createElementNS(ns, 'textPath');
    tp.setAttribute('href', '#ring-path');
    tp.textContent = 'NEXT · NEXT · NEXT · NEXT · NEXT · ';
    rtxt.appendChild(tp); ring.appendChild(rtxt);

    // Over-image ring — white, clipped to media bounds
    var rtxtOver = document.createElementNS(ns, 'text');
    rtxtOver.setAttribute('font-family', 'Diatype Mono Variable, monospace');
    rtxtOver.setAttribute('font-size', '8.5');
    rtxtOver.setAttribute('fill', '#ffffff');
    rtxtOver.setAttribute('letter-spacing', '2.5');
    rtxtOver.setAttribute('clip-path', 'url(#' + clipId + ')');
    var tpOver = document.createElementNS(ns, 'textPath');
    tpOver.setAttribute('href', '#ring-path');
    tpOver.textContent = 'NEXT · NEXT · NEXT · NEXT · NEXT · ';
    rtxtOver.appendChild(tpOver); ring.appendChild(rtxtOver);

    cursor.appendChild(ring);

    wrap.addEventListener('mouseenter', function() {
        cursor.classList.remove('is-link','is-home','is-project','is-phrase');
        cursor.classList.add('is-next');
        if (label) label.textContent = '';
    });
    wrap.addEventListener('mouseleave', function() {
        cursor.classList.remove('is-next');
        if (label) label.textContent = '';
        // Hide clip rect on leave
        clipRect.setAttribute('width', '0');
        clipRect.setAttribute('height', '0');
    });

    // ── Update white ring clip to media bounds in real time ──
    wrap.addEventListener('mousemove', function(e) {
        var mediaEl = stage.querySelector('.studio-feature-media');
        if (!mediaEl) return;
        var r = mediaEl.getBoundingClientRect();
        var cx = e.clientX, cy = e.clientY;
        // SVG viewBox 0-100, cursor 100×100px centred at (cx,cy)
        // → origin of SVG coordinate space is at screen (cx-50, cy-50)
        clipRect.setAttribute('x',      (r.left   - cx + 50).toFixed(1));
        clipRect.setAttribute('y',      (r.top    - cy + 50).toFixed(1));
        clipRect.setAttribute('width',  r.width.toFixed(1));
        clipRect.setAttribute('height', r.height.toFixed(1));
    });

    // ── Founder name hover — purple pill cursor + portrait popup ──
    var founderNames   = document.querySelectorAll('.founder-name');
    var founderPortrait = document.getElementById('founder-portrait');
    founderNames.forEach(function(el) {
        el.addEventListener('mouseenter', function() {
            cursor.classList.remove('is-link', 'is-home', 'is-project', 'is-next');
            cursor.classList.add('is-founder');
            if (label) label.textContent = 'Founder & CEO';
            if (founderPortrait) founderPortrait.classList.add('is-active');
        });
        el.addEventListener('mouseleave', function() {
            cursor.classList.remove('is-founder');
            if (label) label.textContent = '';
            if (founderPortrait) founderPortrait.classList.remove('is-active');
        });
    });

    // ── "award-winning" hover — purple pill cursor + CSSDA badges pop right ──
    var awardNames  = document.querySelectorAll('.award-name');
    var awardBadges = document.getElementById('award-badges-pop');
    awardNames.forEach(function(el) {
        el.addEventListener('mouseenter', function() {
            cursor.classList.remove('is-link', 'is-home', 'is-project', 'is-next');
            cursor.classList.add('is-founder');
            if (label) label.textContent = 'Ta-da!';
            if (awardBadges) awardBadges.classList.add('is-active');
        });
        el.addEventListener('mouseleave', function() {
            cursor.classList.remove('is-founder');
            if (label) label.textContent = '';
            if (awardBadges) awardBadges.classList.remove('is-active');
        });
    });

    // ── Transition: old floats up-out, new rises in from below ──
    function transition(outgoing, incoming) {
        var oldH = stage.offsetHeight;

        stage.style.transition = 'none';
        stage.style.height     = oldH + 'px';

        outgoing.classList.add('sfv-abs');
        outgoing.style.zIndex = '1';

        incoming.classList.add('sfv-abs');
        incoming.style.zIndex   = '2';
        incoming.style.opacity  = '0';
        incoming.style.transform = 'translateY(28px)';
        stage.appendChild(incoming);
        incoming.getBoundingClientRect(); // flush reflow

        // Measure incoming's natural height now (while absolute, same width as in-flow)
        // so we can animate the stage height alongside the image — not after it.
        var newH = incoming.offsetHeight || oldH;

        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                // Stage height slides to new value in sync with the image swap
                stage.style.transition = 'height 0.5s cubic-bezier(0.16,1,0.3,1)';
                stage.style.height     = newH + 'px';

                // Old: drift up and fade out
                outgoing.style.transition = 'opacity 0.38s ease, transform 0.38s ease';
                outgoing.style.opacity    = '0';
                outgoing.style.transform  = 'translateY(-22px) scale(0.97)';

                // New: rise in slightly after old begins leaving
                setTimeout(function() {
                    incoming.style.transition = 'opacity 0.45s ease, transform 0.45s cubic-bezier(0.16,1,0.3,1)';
                    incoming.style.opacity    = '1';
                    incoming.style.transform  = 'translateY(0)';
                }, 60);
            });
        });

        setTimeout(function() {
            if (outgoing.tagName === 'VIDEO') outgoing.pause();
            if (outgoing.parentNode) outgoing.parentNode.removeChild(outgoing);
            outgoing.classList.remove('sfv-abs');
            outgoing.style.opacity = outgoing.style.transform = outgoing.style.transition = outgoing.style.zIndex = '';

            incoming.style.transition = incoming.style.transform = incoming.style.opacity = incoming.style.zIndex = '';
            incoming.classList.remove('sfv-abs');

            // Height animation already finished — just release the explicit value.
            // Natural in-flow height == newH, so no snap.
            stage.style.transition = '';
            stage.style.height     = '';

            if (incoming.tagName === 'VIDEO') incoming.play().catch(function() {});
            currentEl = incoming;
            animating = false;

            if (incoming._reelMeta) typewrite(buildMeta(incoming._reelMeta));
        }, 560);
    }

    // ── Click ──
    wrap.addEventListener('click', function() {
        if (animating) return;
        animating = true;

        var item = dequeue();
        if (!item) { animating = false; return; }
        var incoming = buildEl(item);

        if (item.type === 'video') {
            incoming.setAttribute('preload', 'auto');
            incoming.load();
        }

        var called = false;
        function go() {
            if (called) return;
            called = true;
            transition(currentEl, incoming);
        }

        var ready = item.type === 'video' ? incoming.readyState >= 1 : incoming.complete;
        if (ready) {
            go();
        } else {
            var ev = item.type === 'video' ? 'loadedmetadata' : 'load';
            incoming.addEventListener(ev, go, { once: true });
            setTimeout(go, 800);
        }
    });
})();
</script>

<script is:inline>
// ── Video: pause when out of viewport, resume when in ─────────────
(function() {
    var stage = document.querySelector('.sfv-stage');
    var vid   = document.querySelector('.studio-feature-video');
    if (!stage || !vid || !('IntersectionObserver' in window)) return;

    if (window.innerWidth <= 720) {
        vid.setAttribute('preload', 'none');
    }

    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            var active = stage.querySelector('.studio-feature-media');
            if (!active || active.tagName !== 'VIDEO') return;
            if (entry.isIntersecting) {
                active.play().catch(function() {});
            } else {
                active.pause();
            }
        });
    }, { threshold: 0.15 });

    observer.observe(stage);
    window._studioVidObserver = observer;
})();
</script>

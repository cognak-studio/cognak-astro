        // ── LOGO LIST — replace svg/href/label per client ────────────────
        var logos = [
            { svg: GULF,       href: '#', label: 'Gulf' },
            { svg: QUARTET,    href: '#', label: 'Quartet' },
            { svg: DUVINE,     href: '#', label: 'DuVine' },
            { svg: PIZZAHUT,   href: '#', label: 'Pizza Hut' },
            { svg: HYPR,       href: '#', label: 'Hypr' },
            { svg: HUBSPOT,    href: '#', label: 'HubSpot' },
            { svg: BIG10,      href: '#', label: 'Big Ten' },
            { svg: STRAPI,     href: '#', label: 'Strapi' },
            { svg: STONYFIELD, href: '#', label: 'Stonyfield' },
            { svg: WELLNESS,   href: '#', label: 'Wellness' },
            { svg: MAYABRENNER, href: '#', label: 'Maya Brenner' },
            { svg: HEX,        href: '#', label: 'Hex', cls: 'logo-ring-item--xs' },
            { svg: BOSE,       href: '#', label: 'Bose' },
            { svg: SEC,        href: '#', label: 'SEC' },
            { svg: IQSIGHT,    href: '#', label: 'IQSight' },
            { svg: BUILDKITE,  href: '#', label: 'Buildkite' },
        ];

        var track   = document.getElementById('logo-ring-track');
        var section = document.getElementById('logo-ring-section');
        var N       = logos.length;
        var TAU     = Math.PI * 2;

        var SPEED_NORMAL = 0.000075; // rad/ms — ~140s per revolution
        var SPEED_HOVER  = SPEED_NORMAL * 0.13;

        var currentSpeed = SPEED_NORMAL;
        var targetSpeed  = SPEED_NORMAL;
        var globalAngle  = Math.PI / 2; // first logo starts at front-bottom

        var rx, ry, cx, cy;
        var TILT     = 5 * Math.PI / 180; // left side higher
        var cosTilt  = Math.cos(TILT);
        var sinTilt  = Math.sin(TILT);

        function measure() {
            var rect = track.getBoundingClientRect();
            cx = rect.left + rect.width  / 2;
            cy = rect.top  + rect.height / 2;
            var isMobile = window.innerWidth <= 720;
            rx = isMobile ? window.innerWidth * 0.85 : rect.width * 0.612;
            ry = rx * 0.09;
        }

        var items = logos.map(function(logo) {
            var a = document.createElement('span');
            a.className = 'logo-ring-item' + (logo.cls ? ' ' + logo.cls : '');
            a.setAttribute('aria-label', logo.label);
            a.innerHTML = logo.svg;
            document.body.appendChild(a);
            return a;
        });

        window.addEventListener('resize', measure);

        section.addEventListener('mouseenter', function() { targetSpeed = SPEED_HOVER; });
        section.addEventListener('mouseleave', function() { targetSpeed = SPEED_NORMAL; });

        var lastTs = null;
        var ringFadeStart = null;
        var RING_FADE_DELAY    = 400;   // ms before fade begins
        var RING_FADE_DURATION = 1200;  // ms to go 0→1

        function frame(ts) {
            if (!lastTs) lastTs = ts;
            var dt = Math.min(ts - lastTs, 64);
            lastTs = ts;

            if (ringFadeStart === null) ringFadeStart = ts + RING_FADE_DELAY;
            var ringRaw = Math.max(0, Math.min(1, (ts - ringFadeStart) / RING_FADE_DURATION));
            var ringOpacity = ringRaw * ringRaw * (3 - 2 * ringRaw); // smoothstep

            measure(); // update cx/cy as page scrolls

            currentSpeed += (targetSpeed - currentSpeed) * 0.055;
            globalAngle  += currentSpeed * dt;

            for (var i = 0; i < N; i++) {
                var theta = globalAngle + (i / N) * TAU;
                var cosT  = Math.cos(theta);
                var sinT  = Math.sin(theta); // +1 = front/bottom, -1 = back/top

                // raw ellipse offset, then rotate by TILT
                var ex = rx * cosT;
                var ey = ry * sinT;
                var screenX = cx + ex * cosTilt - ey * sinTilt;
                var screenY = cy + ex * sinTilt + ey * cosTilt;

                var t       = (sinT + 1) * 0.5;              // 0 = back, 1 = front
                var tEased  = Math.pow(t, 1.5);              // extended fade: sides dimmer
                var scale   = 0.55 + t * 0.51;              // 0.55 → 1.06
                var opacity = (0.20 + tEased * 0.77) * ringOpacity; // fades in on load
                var zIdx    = Math.round(t * 100);

                // depth blur: back logos (t≈0) get up to 1.8px blur, front (t≈1) get none
                var blurPx = (1 - tEased) * 1.8;

                var el = items[i];
                el.style.left      = screenX + 'px';
                el.style.top       = screenY + 'px';
                el.style.opacity   = opacity;
                el.style.zIndex    = zIdx;
                el.style.filter    = blurPx > 0.15 ? 'blur(' + blurPx.toFixed(2) + 'px)' : '';
                el.style.transform = 'translate(-50%,-50%) scale(' + scale.toFixed(4) + ')';
            }

            requestAnimationFrame(frame);
        }

        requestAnimationFrame(frame);
    })();
    </script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  page="studio"
  title="Studio – COGNAK | Design & Development"
  description="Learn about the studio behind COGNAK — a creative studio that blends design, code, and strategy to build premium digital and print experiences."
  ogUrl="https://cognak.com/studio/"
  pageBg="#18151A"
>
<style is:inline>
html, body { background-color: #18151A !important; }
body { overflow-x: clip; }
.studio-archive.about-template { overflow-x: hidden !important; min-height: 0 !important; }
.studio-archive.projects-archive { padding-bottom: 0 !important; }
.home-bottom-bar.inner-page-nav {
    background: rgba(14, 14, 14, 0.75) !important;
    z-index: 999999 !important;
    backdrop-filter: blur(6px) !important;
    -webkit-backdrop-filter: blur(6px) !important;
}
.home-bottom-bar.inner-page-nav img {
    filter: none !important;
}
.home-bottom-bar.inner-page-nav .home-bottom-email,
.home-bottom-bar.inner-page-nav .home-bottom-location,
.home-bottom-bar.inner-page-nav .inner-nav-links a {
    color: rgba(255,255,255,0.6) !important;
}
.home-bottom-bar.inner-page-nav .pulse-dot {
    color: #FFB2E4 !important;
}
.studio-start-wrap .projects-start-link { color: #fff !important; }
.studio-start-wrap .projects-start-link:hover { color: #FFB2E4 !important; }
.studio-start-wrap .availability-sub    { color: rgba(255,255,255,0.6) !important; }
.studio-start-wrap .avail-dot           { color: #AAFF00 !important; }
@keyframes letter-rainbow-in {
    0%   { color: inherit; }
    20%  { color: #FFD6F2; }
    40%  { color: #FFBAE8; }
    62%  { color: #FFB2E4; }
    82%  { color: #E890D0; }
    100% { color: #FFB2E4; }
}
.home-bottom-bar.inner-page-nav .home-bottom-email:hover,
.home-bottom-bar.inner-page-nav .inner-nav-links a:hover {
    color: #9F50FF !important;
}
</style>


<main id="cognak-main"><section class="projects-archive studio-archive about-template">
    <div class="about-webgl" data-us-project="XEfPUaskhvBG8NTBRTA1"></div>

    <div class="studio-display-copy">
        <h1 class="studio-display-headline">Our <span class="headline-pink">studio</span> designs work that holds up and builds systems that last. We don't overcomplicate it. We work directly with the people who value the difference.</h1>
    </div>

    <!-- ═══ LOGO RING ═══════════════════════════════════════════════ -->
    <div class="logo-ring-section" id="logo-ring-section">
        <div class="logo-ring-track" id="logo-ring-track"></div>
    </div>
    <style is:inline>
    .logo-ring-section {
        height: 360px;
        margin: -2px 0 40px;
        overflow: visible;
    }
    .logo-ring-track {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: visible;
    }
    .logo-ring-item {
        position: fixed;
        display: block;
        line-height: 0;
        cursor: default;
        pointer-events: none;
        transform-origin: center center;
    }
    .logo-ring-item svg {
        display: block;
        width: 130px;
        height: 44px;
        pointer-events: none;
    }
    .logo-ring-item--sm svg {
        width: 65px !important;
        height: 22px !important;
    }
    .logo-ring-item--xs svg {
        width: 54px !important;
        height: 22px !important;
    }
    .logo-ring-item:hover {
        opacity: 0.55;
        transition: opacity 0.25s ease;
    }
    </style>

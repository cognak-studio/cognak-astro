    })();
    </script>

<script is:inline>
(function() {
    var webglEl = document.querySelector('.about-webgl');
    if (!webglEl) return;
    var observer = new MutationObserver(function(mutations) {
        for (var i = 0; i < mutations.length; i++) {
            if (mutations[i].addedNodes.length) {
                observer.disconnect();
                setTimeout(function() {
                    webglEl.classList.add('webgl-ready');
                }, 100);
                return;
            }
        }
    });
    observer.observe(webglEl, { childList: true });
    // Fallback: if nothing appears within 3s, fade in anyway
    setTimeout(function() { webglEl.classList.add('webgl-ready'); }, 3000);
})();
</script>


    <script is:inline>
    // Stagger-fade capabilities on scroll
    (function() {
        var items = document.querySelectorAll('.capabilities-list li');
        if (!items.length || !('IntersectionObserver' in window)) {
            items.forEach(function(li) { li.classList.add('capability-visible'); });
            return;
        }
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (!entry.isIntersecting) return;
                var li = entry.target;
                var idx = Array.prototype.indexOf.call(items, li);
                setTimeout(function() { li.classList.add('capability-visible'); }, idx * 45);
                observer.unobserve(li);
            });
        }, { threshold: 0, rootMargin: '0px 0px -5% 0px' });
        items.forEach(function(li) { observer.observe(li); });
    })();
    </script>


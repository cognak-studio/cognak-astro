      var canvas = document.getElementById('colophon-anatomy');
      if (!canvas || !canvas.getContext) return;
      var ctx = canvas.getContext('2d');
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var order = DATA.order;
      var glyphs = DATA.glyphs;
      var meta = DATA.meta;
      var N = glyphs[order[0]][0].length;

      var dpr = 1, vw = 0, vh = 0;
      function resize() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        vw = window.innerWidth;
        vh = window.innerHeight;
        canvas.width = Math.round(vw * dpr);
        canvas.height = Math.round(vh * dpr);
      }
      resize();
      window.addEventListener('resize', resize);

      // layout: glyph drawing box, offset right on desktop, centered on mobile
      function layout() {
        var gh = vh * 0.82;
        var scale = gh / (meta.maxy - meta.miny);
        var gw = (meta.maxx - meta.minx) * scale;
        var cx = vw > 900 ? vw * 0.72 : vw * 0.5;
        var cy = vh * 0.52;
        return {
          scale: scale,
          ox: cx - ((meta.minx + meta.maxx) / 2) * scale,
          oy: cy + ((meta.miny + meta.maxy) / 2) * scale
        };

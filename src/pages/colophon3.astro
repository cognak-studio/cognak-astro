---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  page="colophon"
  title="Colophon – COGNAK"
  description="A note on how this site is set — the type, the tools, the hands."
  ogUrl="https://cognak.com/colophon3/"
  noindex={true}
  pageBg="#0E06D2"
>
  <canvas id="colophon-grid" aria-hidden="true"></canvas>

  <main id="cognak-main"><section class="colophon">

    <p class="colophon-eyebrow">Colophon</p>

    <h1 class="colophon-headline">Set in <em>ABC&nbsp;Diatype</em>.</h1>

    <div class="colophon-body">
      <p>You found the quiet page. Every word on cognak.com is set in <strong>ABC&nbsp;Diatype</strong>, a grotesque drawn by <a href="https://abcdinamo.com/typefaces/diatype" target="_blank" rel="noopener">Dinamo</a> in Basel &amp; Berlin, chosen for the way it stays neutral until you look closely, then reveals a little warmth in the curves. Code and figures fall back to <strong>ABC&nbsp;Diatype Mono</strong>.</p>

      <p>The faces are self-hosted as <code>woff2</code> (Regular, Medium, Bold, and the Mono) so nothing about your visit is handed to a font CDN.</p>

      <p class="colophon-spec">
        <span>Typeface</span><span>ABC Diatype &amp; ABC Diatype Mono — <a href="https://abcdinamo.com/typefaces/diatype" target="_blank" rel="noopener">Dinamo</a></span>
        <span>Built with</span><span><a href="https://astro.build" target="_blank" rel="noopener">Astro</a>, hand-written HTML/CSS/JS, WebGL</span>
        <span>Motion</span><span><a href="https://lenis.darkroom.engineering" target="_blank" rel="noopener">Lenis</a> smooth scroll, <a href="https://www.unicorn.studio" target="_blank" rel="noopener">UnicornStudio</a>, custom canvas</span>
        <span>Served from</span><span><a href="https://vercel.com" target="_blank" rel="noopener">Vercel</a></span>
        <span>Made in</span><span>Los Angeles, California</span>
      </p>

      <p class="colophon-sign">No page builders. No templates. Built by hand at COGNAK. If you care about this sort of thing, so do we: <a href="mailto:hello@cognak.com">hello@cognak.com</a>.</p>
    </div>

  </section></main>

  <style is:inline>
    html, body { background-color: #0E06D2 !important; }

    #colophon-grid {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      z-index: 0;
      pointer-events: none;
    }
    #cognak-main { position: relative; z-index: 1; }

    .home-bottom-bar.inner-page-nav.colophon-nav {
      background: rgba(7, 0, 172, 0.80) !important;
    }
    .home-bottom-bar.inner-page-nav.colophon-nav .home-bottom-email,
    .home-bottom-bar.inner-page-nav.colophon-nav .home-bottom-location,
    .home-bottom-bar.inner-page-nav.colophon-nav .inner-nav-links a,
    .home-bottom-bar.inner-page-nav.colophon-nav .pulse-dot {
      color: #ffffff !important;
    }

    .colophon {
      max-width: 720px;
      margin: 0 auto;
      padding: calc(7vh + 75px) 6vw 22vh;
      color: #f4f4ee;
      font-family: 'Diatype Variable', sans-serif;
    }
    .colophon-eyebrow,
    .colophon-headline,
    .colophon-body > * {
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .colophon-eyebrow.is-in,
    .colophon-headline.is-in,
    .colophon-body > *.is-in {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .colophon-eyebrow,
      .colophon-headline,
      .colophon-body > * {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
    .colophon-eyebrow {
      font-family: 'Diatype Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #c7c9d8;
      margin: 0 0 2.4rem;
    }
    .colophon-headline {
      font-size: clamp(2.6rem, 7vw, 4.6rem);
      font-weight: 500;
      line-height: 1.02;
      letter-spacing: -0.02em;
      margin: 0 0 3.2rem;
      color: #f6f6f0;
    }
    .colophon-headline em {
      font-style: italic;
      font-weight: 400;
      color: #b6ff2e;
    }
    .colophon-body p {
      font-size: 1.06rem;
      line-height: 1.7;
      color: #e8e8de;
      margin: 0 0 1.6rem;
      max-width: 58ch;
    }
    .colophon-body a {
      color: #b6ff2e;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
    }
    .colophon-body strong { color: #ffffff; font-weight: 500; }
    .colophon-body code {
      font-family: 'Diatype Mono', monospace;
      font-size: 0.88em;
      color: #b6ff2e;
    }
    .colophon-spec {
      display: grid;
      grid-template-columns: max-content 1fr;
      align-items: baseline;
      gap: 0.55rem 2rem;
      font-family: 'Diatype Mono', monospace;
      font-size: 0.82rem;
      line-height: 1.5;
      color: #e8e8de;
      border-top: 1px solid rgba(244,244,238,0.28);
      border-bottom: 1px solid rgba(244,244,238,0.28);
      padding: 2rem 0;
      margin: 2.6rem 0 !important;
    }
    .colophon-spec a {
      color: inherit;
      text-decoration: none;
      transition: color 0.25s ease;
    }
    .colophon-spec a:hover { color: #b6ff2e; }
    .colophon-spec span:nth-child(odd) {
      color: #a9abbd;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.72rem;
    }
    .colophon-sign {
      font-size: 0.98rem !important;
      color: #c7c9d8 !important;
    }
    @media (max-width: 600px) {
      .colophon-spec { grid-template-columns: 1fr; gap: 0.15rem; }
      .colophon-spec span:nth-child(odd) { margin-top: 1rem; }
      .colophon-spec span:nth-child(2) { margin-top: 0; }
    }
  </style>

  <script is:inline>
    if (history.scrollRestoration) { history.scrollRestoration = 'manual'; }
    window.scrollTo(0, 0);
    (function () {
      var els = document.querySelectorAll('.colophon-eyebrow, .colophon-headline, .colophon-body > *');
      if (!els.length || !('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('is-in'); });
        return;
      }
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var idx = Array.prototype.indexOf.call(els, el);
          setTimeout(function () { el.classList.add('is-in'); }, idx * 70);
          observer.unobserve(el);
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { observer.observe(el); });
    })();
    console.log(
      '%cCOGNAK%c  set in ABC Diatype — Dinamo.\nBuilt by hand in Los Angeles. hello@cognak.com',
      'font: 600 13px "Diatype Mono", monospace; letter-spacing:.24em; color:#f3f0ee;',
      'font: 12px/1.6 "Diatype Mono", monospace; color:#8b8790;'
    );
  </script>

  <script is:inline>
    (function () {
      var canvas = document.getElementById('colophon-grid');
      if (!canvas || !canvas.getContext) return;
      var ctx = canvas.getContext('2d');
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var touch = window.matchMedia('(hover: none)').matches;

      var dpr = 1, vw = 0, vh = 0, spacing = 28.8;
      function resize() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        vw = window.innerWidth;
        vh = window.innerHeight;
        canvas.width = Math.round(vw * dpr);
        canvas.height = Math.round(vh * dpr);
        var p = document.querySelector('.colophon-body p');
        if (p) {
          var lh = parseFloat(getComputedStyle(p).lineHeight);
          if (lh > 8) spacing = lh;
        }
      }
      resize();
      window.addEventListener('resize', resize);

      var mx = -9999, my = -9999, tx = -9999, ty = -9999;
      if (!touch) {
        window.addEventListener('mousemove', function (e) { tx = e.clientX; ty = e.clientY; });
        document.addEventListener('mouseleave', function () { tx = -9999; ty = -9999; });
      }

      var SIGMA = 95, AMP = 7, STEP = 22;

      function drawLine(y, alpha, rippling) {
        ctx.strokeStyle = 'rgba(244,244,238,' + alpha + ')';
        ctx.beginPath();
        if (!rippling || my < -999 || Math.abs(y - my) > SIGMA * 2.2) {
          ctx.moveTo(0, y);
          ctx.lineTo(vw, y);
        } else {
          var first = true;
          for (var x = 0; x <= vw + STEP; x += STEP) {
            var dx = x - mx, dy = y - my;
            var d2 = dx * dx + dy * dy;
            var off = -AMP * Math.sign(dy || 1) * Math.exp(-d2 / (2 * SIGMA * SIGMA));
            if (first) { ctx.moveTo(x, y + off); first = false; }
            else ctx.lineTo(x, y + off);
          }
        }
        ctx.stroke();
      }

      function cropMark(x, y) {
        var L = 9, G = 4;
        ctx.strokeStyle = 'rgba(182,255,46,0.20)';
        ctx.beginPath();
        ctx.moveTo(x - G - L, y); ctx.lineTo(x - G, y);
        ctx.moveTo(x + G, y); ctx.lineTo(x + G + L, y);
        ctx.moveTo(x, y - G - L); ctx.lineTo(x, y - G);
        ctx.moveTo(x, y + G); ctx.lineTo(x, y + G + L);
        ctx.stroke();
      }

      function frame(now) {
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, vw, vh);
        ctx.lineWidth = 1;

        mx += (tx - mx) * 0.12;
        my += (ty - my) * 0.12;

        var scrollY = window.scrollY || 0;
        var offset = spacing - (scrollY % spacing);
        var t = now * 0.001;

        for (var y = offset - spacing; y < vh + spacing; y += spacing) {
          var breath = reduced ? 1 : (0.7 + 0.3 * Math.sin(t * 0.45 - y * 0.006));
          drawLine(y, 0.052 * breath, !reduced && !touch);
        }

        var body = document.querySelector('.colophon-body');
        if (body) {
          var r = body.getBoundingClientRect();
          var ga = reduced ? 0.10 : (0.08 + 0.04 * Math.sin(t * 0.3));
          ctx.strokeStyle = 'rgba(244,244,238,' + ga + ')';
          ctx.beginPath();
          ctx.moveTo(r.left - 24, 0); ctx.lineTo(r.left - 24, vh);
          ctx.moveTo(r.right + 24, 0); ctx.lineTo(r.right + 24, vh);
          ctx.stroke();

          var head = document.querySelector('.colophon-eyebrow');
          if (head) {
            var hr = head.getBoundingClientRect();
            cropMark(r.left - 24, hr.top - 18);
            cropMark(r.right + 24, hr.top - 18);
          }
          cropMark(r.left - 24, r.bottom + 26);
          cropMark(r.right + 24, r.bottom + 26);
        }

        if (!reduced) requestAnimationFrame(frame);
      }

      if (reduced) {
        frame(performance.now());
        window.addEventListener('resize', function () { frame(performance.now()); });
        window.addEventListener('scroll', function () { frame(performance.now()); }, { passive: true });
      } else {
        requestAnimationFrame(frame);
      }
    })();
  </script>
</BaseLayout>
